# Stage 1: Build phonewave
FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/phonewave ./cmd/phonewave/

# Stage 2: Runtime (keeps Go toolchain for go test -tags e2e)
FROM golang:1.25-alpine AS runtime
RUN apk add --no-cache git
COPY --from=builder /bin/phonewave /usr/local/bin/phonewave
COPY --from=builder /src /src
WORKDIR /src
